# ─── Stripe ───
# For local dev, paste your sk_test_... key here.
# In Railway production, set this to a Stripe restricted key (rk_live_...) with scopes:
#   - Products / Prices: read+write
#   - Checkout Sessions: read+write
#   - Payment Intents: read+write
#   - Customers: read
#   - Webhook endpoints: read (for verifying)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Existing $95 audit Price ID (created 2026-04-26 — see project memory)
STRIPE_PRICE_AUDIT_95=price_1TQRzgL6wogExyvxCdhIZVJo

# Created by `npm run create:products` (one-time)
STRIPE_PRICE_COMPETITOR_147=price_...
STRIPE_PRICE_BRAND_REP_147=price_...

# ─── Slack SDR notifications (business channel, NOT personal Telegram) ───
# Create at https://api.slack.com/apps → Incoming Webhooks → Add New Webhook to Workspace
# Pick the channel where the SDR / sales team should receive purchase pings.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── URLs ───
# Where Stripe redirects after successful checkout (the upsell-2 page).
SUCCESS_URL=https://your-ghl-funnel-host.example.com/upsell-2
# Where the user goes after declining (or completing) the upsell.
CALENDLY_URL=https://calendly.com/zen-media/ai-visibility-pack-discovery-call-with-duran-inci
# Where Stripe sends them on cancel.
CANCEL_URL=https://your-ghl-funnel-host.example.com/95

# ─── Server ───
PORT=3000
NODE_ENV=production
